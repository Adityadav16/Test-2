student_utils.py

def get_grade(avg, pass_mark=40):

    if avg >= 90:
        return "A"

    elif avg >= 75:
        return "B"

    elif avg >= 50:
        return "C"

    elif avg >= pass_mark:
        return "D"

    else:
        return "Fail"


def calculate_average(*marks):
    return sum(marks) / len(marks)

