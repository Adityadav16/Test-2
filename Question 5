def fibonacci(n):
    a = 0
    b = 1

    for i in range(n):
        yield a
        a, b = b, a + b


print("Using for loop:")

for num in fibonacci(10):
    print(num, end=" ")

print()

print("Using next():")

gen = fibonacci(10)

print(next(gen))
print(next(gen))
print(next(gen))
print(next(gen))
