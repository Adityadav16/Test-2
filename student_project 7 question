import student_utils
import json

students = []

for i in range(3):

    print("\nStudent", i + 1)

    name = input("Enter Name: ")

    while True:

        try:

            m1 = float(input("Enter Marks of Subject 1: "))
            m2 = float(input("Enter Marks of Subject 2: "))
            m3 = float(input("Enter Marks of Subject 3: "))

            if m1 < 0 or m1 > 100 or m2 < 0 or m2 > 100 or m3 < 0 or m3 > 100:
                raise ValueError

            break

        except ValueError:
            print("Invalid marks! Please enter values between 0 and 100.")

    average = student_utils.calculate_average(m1, m2, m3)

    grade = student_utils.get_grade(average)

    students.append({
        "name": name,
        "marks": [m1, m2, m3],
        "average": average,
        "grade": grade
    })

# Write report.txt
file = open("report.txt", "w")

for student in students:

    file.write(
        f"Name: {student['name']} | Average: {student['average']:.2f} | Grade: {student['grade']}\n"
    )

file.close()

# Write students.json
file = open("students.json", "w")

json.dump(students, file, indent=4)

file.close()


print("\nContents of report.txt\n")

